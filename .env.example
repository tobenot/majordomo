# 人设层 API 凭证。不配也能跑：persona.mode=auto 时会自动降级到离线模板。

# openai: OpenAI-compatible /chat/completions
# anthropic: Anthropic Messages API /v1/messages
PERSONA_API_FORMAT=openai

PERSONA_API_KEY=

# OpenAI-compatible 示例：https://api.openai.com/v1 或自建网关。
# Anthropic 官方接口可留空，默认 https://api.anthropic.com。
PERSONA_API_BASE=

# OpenAI-compatible 示例：gpt-4o-mini / glm-4-flash。
# Anthropic 示例：claude-3-5-haiku-latest。
PERSONA_MODEL=
