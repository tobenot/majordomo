// majordomo 配置示例。复制为 config.jsonc 后修改（config.jsonc 不进版本库）。
// 全局配置优先从 ~/.majordomo/config.jsonc 读取，其次是项目根目录 ./config.jsonc。
{
  // ── 网络 ──────────────────────────────────────────────
  // core daemon 监听地址。初期只听 localhost；未来远程接入再改 host/加 TLS。
  "host": "127.0.0.1",
  "port": 4317,

  // ── Profile：claude / claude-internal / tclaude 一键切换 ──
  // 关键坑：内网版个人规则目录是 .claude-internal（它自己会说成 .claude，那是错的）。
  // 切换 activeProfile 只影响"新开"的 session，已跑的不动。
  "activeProfile": "claude",
  "profiles": {
    "claude": {
      "command": "claude",
      "personalDir": "~/.claude"
    },
    "internal": {
      "command": "claude-internal",
      "personalDir": "~/.claude-internal"
    },
    "tclaude": {
      "command": "tclaude",
      "personalDir": "~/.tclaude"
    }
  },

  // 工作层权限模式：默认使用 Claude Code 的 auto 分类器；需要人工介入时走前端权限确认。
  // 可选："default" | "acceptEdits" | "bypassPermissions" | "plan" | "dontAsk" | "auto"。
  "permissionMode": "auto",

  // ── 工作层 worker ───────────────────────────────────────
  // engine: "auto" | "sdk" | "mock"
  //   auto → 优先 @anthropic-ai/claude-agent-sdk 常驻会话；没有 SDK 则 mock
  //   sdk  → 强制走 TypeScript Agent SDK 常驻会话
  //   mock → 回显引擎，无需任何凭证，用于演示整条链路
  "worker": {
    "engine": "auto",
    "maxTurns": 8,
    "timeoutMs": 600000,
    // "allowedTools": ["Read", "Grep", "Glob"],
    // "disallowedTools": ["Bash(git push)"]
  },

  // ── 人设层 persona ──────────────────────────────────────
  // mode: "auto" | "api" | "template"
  //   auto    → 有 API key 走 api，否则走离线模板
  //   api     → OpenAI-compatible / Anthropic Messages API（密钥放 .env）
  //   template→ 离线模板，无需密钥
  // 具体 PERSONA_API_FORMAT/key/base/model 放 .env，不写进配置文件。

  "persona": {
    "mode": "auto",
    "name": "指挥官",
    "style": "cat-girl-maid"
  },

  // ── 通知 notifier（可插拔，按顺序全部触发）────────────────
  // powershell：复用第二代 tools/notify-done 脚本（提示音/浮窗/TTS/日记）
  // console：跨平台降级，仅打印
  "notifiers": ["powershell", "console"],

  // 日记目录（相对项目根）。沿用第二代习惯。
  "diaryDir": ".codebuddy/memory",

  // ── 工作流 hooks（可选，不配置则 after_task 默认 diary+notify）────────
  // 可用事件：after_task / on_session_create / on_session_close / on_error
  // 可用类型：diary / notify / shell / markdown_report
  // 显式设空数组 [] 可禁用默认行为。
  // shell hook 可用环境变量: MJ_SESSION_ID MJ_SESSION_NAME MJ_CWD MJ_PROFILE MJ_TEXT MJ_EVENT_TYPE
  // "hooks": {
  //   "after_task": [
  //     { "type": "diary" },
  //     { "type": "notify" },
  //     { "type": "shell", "command": "echo 任务完成: %MJ_TEXT%", "cwd": "." },
  //     { "type": "markdown_report", "output_dir": ".majordomo/reports" }
  //   ],
  //   "on_session_create": [
  //     { "type": "shell", "command": "echo 新会话: %MJ_SESSION_NAME%" }
  //   ],
  //   "on_session_close": [],
  //   "on_error": [
  //     { "type": "notify" }
  //   ]
  // }
}
